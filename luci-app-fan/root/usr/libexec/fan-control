#!/bin/sh
# author: jjm2473
# Refactored to use shared library fan-lib.sh

SAVE=/tmp/run/fanTP
PWM_SAVE=/tmp/run/fanPWM
PID_SAVE=/tmp/run/fanPID
ADAPT_SAVE=/tmp/run/fanADAPT
ACTION=$1
shift

# Source shared library
. /usr/libexec/fan-lib.sh

ensure_cache_dir() {
    mkdir -p "${SAVE%/*}"
}

# Read PID parameters from UCI
read_uci_pid_params() {
    local kp ki kd setpoint

    kp=$(read_uci_uint pid_kp) || kp=200
    ki=$(read_uci_uint pid_ki) || ki=50
    kd=$(read_uci_uint pid_kd) || kd=100
    setpoint=$(read_uci_temp_milli pid_setpoint) || setpoint=60000

    # Clamp values
    kp=$(clamp_uint "$kp" 0 1000)
    ki=$(clamp_uint "$ki" 0 500)
    kd=$(clamp_uint "$kd" 0 500)
    setpoint=$(clamp_uint "$setpoint" 30000 100000)

    printf '%s %s %s %s\n' "$kp" "$ki" "$kd" "$setpoint"
}

# Load PID state from cache
load_pid_state() {
    if [ -s "$PID_SAVE" ]; then
        cat "$PID_SAVE"
        return 0
    fi
    echo "0 0 0"
    return 0
}

# Save PID state to cache
save_pid_state() {
    local error=$1
    local integral=$2
    local prev_temp=$3

    ensure_cache_dir
    printf '%d %d %d\n' "$error" "$integral" "$prev_temp" > "$PID_SAVE"
}

get_fan_tp_cached() {
    ensure_cache_dir

    if [ -s "$SAVE" ]; then
        cat "$SAVE"
        return 0
    fi

    rm -f "$SAVE"
    get_fan_tp >"$SAVE"
    [ -s "$SAVE" ]
}

get_fan_tp_user() {
    set -- $(get_fan_tp_cached)
    [ -n "$1" ] && [ -n "$2" ] || return 1

    on_temp=$(cat "/sys/class/thermal/$1/trip_point_${2}_temp" 2>/dev/null) || {
        rm -f "$SAVE"
        set -- $(get_fan_tp_cached)
        [ -n "$1" ] && [ -n "$2" ] || return 1
        on_temp=$(cat "/sys/class/thermal/$1/trip_point_${2}_temp" 2>/dev/null) || return 1
    }

    echo "$1" "$2" "$on_temp" "$4"
    return 0
}

init_fan_tp() {
    ensure_cache_dir
    [ -s "$SAVE" ] || get_fan_tp >"$SAVE"
}

resolve_pwm_hwmon_cached() {
    ensure_cache_dir

    if [ -s "$PWM_SAVE" ]; then
        cached=$(cat "$PWM_SAVE" 2>/dev/null)
        PWM_HWMON=${cached%%|*}
        PWM_NAME=${cached#*|}

        if [ -d "$PWM_HWMON" ] && [ -w "$PWM_HWMON/pwm1" ]; then
            PWM_PATH="$PWM_HWMON/pwm1"
            PWM_ENABLE_PATH=''
            PWM_RPM_PATH=''
            [ -w "$PWM_HWMON/pwm1_enable" ] && PWM_ENABLE_PATH="$PWM_HWMON/pwm1_enable"
            # Find RPM path without recursive call
            candidate=$(find_rpm_candidate_in_dir "$PWM_HWMON") || candidate=''
            if [ -n "$candidate" ]; then
                PWM_RPM_PATH="$candidate"
            fi
            return 0
        fi
    fi

    resolve_pwm_hwmon || return 1
    printf '%s|%s\n' "$PWM_HWMON" "$PWM_NAME" >"$PWM_SAVE"
    return 0
}

set_pwm_raw() {
    local raw=$1
    local current_raw=''
    local current_enable=''

    is_uint "$raw" || {
        echo 'PWM value must be an unsigned integer' >&2
        return 1
    }

    raw=$(clamp_uint "$raw" 0 255)
    resolve_pwm_hwmon_cached || return 1

    current_raw=$(read_number "$PWM_PATH" 2>/dev/null) || current_raw=''
    [ -n "$PWM_ENABLE_PATH" ] && current_enable=$(read_trimmed "$PWM_ENABLE_PATH" 2>/dev/null) || true

    if [ "$current_raw" = "$raw" ] && { [ -z "$PWM_ENABLE_PATH" ] || [ "$current_enable" = '1' ]; }; then
        return 0
    fi

    if [ -n "$PWM_ENABLE_PATH" ]; then
        # Direct pwm1 writes require manual mode; mode 2 commonly means hardware auto.
        [ "$current_enable" = '1' ] || echo 1 >"$PWM_ENABLE_PATH" 2>/dev/null || true
    fi

    [ "$current_raw" = "$raw" ] || echo "$raw" >"$PWM_PATH"
}

disable_pwm() {
    local current_raw=''
    local current_enable=''

    resolve_pwm_hwmon_cached || return 0

    current_raw=$(read_number "$PWM_PATH" 2>/dev/null) || current_raw=''
    [ -n "$PWM_ENABLE_PATH" ] && current_enable=$(read_trimmed "$PWM_ENABLE_PATH" 2>/dev/null) || true

    if [ "$current_raw" = '0' ] && { [ -z "$PWM_ENABLE_PATH" ] || [ "$current_enable" = '1' ]; }; then
        return 0
    fi

    if [ -n "$PWM_ENABLE_PATH" ]; then
        [ "$current_enable" = '1' ] || echo 1 >"$PWM_ENABLE_PATH" 2>/dev/null || true
    fi

    [ "$current_raw" = '0' ] || echo 0 >"$PWM_PATH" 2>/dev/null || true
}

get_pwm_status() {
    resolve_pwm_hwmon_cached || return 1

    local pwm_raw=$(read_number "$PWM_PATH") || pwm_raw=''
    local pwm_enable=''
    local pwm_rpm=''
    local pwm_percent=''

    [ -n "$PWM_ENABLE_PATH" ] && pwm_enable=$(read_trimmed "$PWM_ENABLE_PATH") || true
    [ -n "$PWM_RPM_PATH" ] && pwm_rpm=$(read_number "$PWM_RPM_PATH") || true

    if is_uint "$pwm_raw"; then
        pwm_percent=$(pwm_to_percent "$pwm_raw")
    else
        pwm_percent=''
    fi

    printf '%s %s %s %s %s %s\n' "$PWM_HWMON" "$PWM_NAME" "$pwm_raw" "$pwm_percent" "$pwm_enable" "$pwm_rpm"
}

load_trip_defaults() {
    DEFAULT_ON_MILLI=''
    DEFAULT_OFF_MILLI=''
    DEFAULT_NEXT_MILLI=''

    set -- $(get_fan_tp_user 2>/dev/null)
    [ -n "$1" ] && [ -n "$2" ] || return 0

    DEFAULT_ON_MILLI=$3
    DEFAULT_NEXT_MILLI=$4
    hyst=$(read_trimmed "/sys/class/thermal/$1/trip_point_${2}_hyst") || hyst=''
    is_uint "$hyst" || hyst=''

    if [ -n "$DEFAULT_ON_MILLI" ] && [ -n "$hyst" ]; then
        DEFAULT_OFF_MILLI=$((DEFAULT_ON_MILLI - hyst))
    fi
}

# param: ON_TEMP [OFF_TEMP]
# OFF_TEMP = ON_TEMP - 5000 if not set
# ex. 60000 55000
set_fan_tp() {
    local on_temp=$1
    local off_temp=$2
    local current_on=''
    local current_hyst=''

    [ -n "$on_temp" ] || {
        echo 'ON_TEMP must be present' >&2
        return 1
    }

    if [ -z "$off_temp" ]; then
        [ "$on_temp" -gt 5000 ] || {
            echo 'ON_TEMP must greater than 5000 when OFF_TEMP not present' >&2
            return 1
        }

        off_temp=$((on_temp - 5000))
    fi

    [ "$on_temp" -gt "$off_temp" ] || {
        echo 'ON_TEMP must greater than OFF_TEMP' >&2
        return 1
    }

    hyst=$((on_temp - off_temp))

    set -- $(get_fan_tp_cached)
    [ -n "$1" ] && [ -n "$2" ] || return 1
    [ -d "/sys/class/thermal/$1" ] || return 1

    if [ -n "$4" ] && [ "$on_temp" -ge "$4" ]; then
        on_temp=$(( $4 - 5000 ))
        echo "WARN: ON_TEMP greater than next TP $4, fixed to $on_temp" >&2
    fi

    current_on=$(read_number "/sys/class/thermal/$1/trip_point_${2}_temp" 2>/dev/null) || current_on=''
    current_hyst=$(read_number "/sys/class/thermal/$1/trip_point_${2}_hyst" 2>/dev/null) || current_hyst=''

    if [ "$current_on" = "$on_temp" ] && [ "$current_hyst" = "$hyst" ]; then
        return 0
    fi

    echo "$on_temp" > "/sys/class/thermal/$1/trip_point_${2}_temp"
    echo "$hyst" > "/sys/class/thermal/$1/trip_point_${2}_hyst"
}

# print: current thermal sensor value and fan on temp
# Pass any non-empty argument to skip smart window resolution (PID mode)
get_temp() {
    local skip_window=$1

    if [ -z "$skip_window" ]; then
        resolve_smart_window_milli
        trip_temp=$SMART_WINDOW_ON_MILLI
    else
        trip_temp=0
    fi

    resolve_primary_thermal_zone 2>/dev/null; zone=$PRIMARY_ZONE || zone=''
    if [ -n "$zone" ] && [ -f "/sys/class/thermal/$zone/temp" ]; then
        temp=$(cat "/sys/class/thermal/$zone/temp" 2>/dev/null) || return 1
        echo "$temp $trip_temp"
        return 0
    fi

    set -- $(get_fan_tp_cached 2>/dev/null)
    if [ -n "$1" ] && [ -n "$2" ] && [ -f "/sys/class/thermal/$1/temp" ]; then
        temp=$(cat "/sys/class/thermal/$1/temp" 2>/dev/null) || return 1
        echo "$temp $trip_temp"
        return 0
    fi

    return 1
}

apply_current_config() {
    local enabled=$(uci -q get 'luci-fan.@luci-fan[0].enabled' 2>/dev/null)
    [ "$enabled" = '1' ] || enabled=0

    local mode=$(read_mode)
    local manual_pwm=$(read_uci_uint manual_pwm) || manual_pwm=70
    local interval=$(read_uci_uint poll_interval) || interval=5
    interval=$(clamp_uint "$interval" 1 30)

    if [ "$enabled" != '1' ]; then
        disable_pwm
        rm -f "$PID_SAVE"
        rm -f "$ADAPT_SAVE"
        return 0
    fi

    if [ "$mode" = 'pid' ]; then
        # PID control mode with adaptive auto-tuning
        if resolve_pwm_hwmon_cached; then
            set -- $(get_temp skip_window 2>/dev/null)
            temp_milli=$1

            [ -n "$temp_milli" ] || return 1

            # Read base PID parameters from UCI
            set -- $(read_uci_pid_params)
            local base_kp=$1
            local base_ki=$2
            local base_kd=$3
            local setpoint=$4

            # Load PID state
            set -- $(load_pid_state)
            local last_error=$1
            local integral_sum=$2
            local prev_temp=$3

            # Run combined adaptive PID (auto-tune + PID in one call)
            ensure_cache_dir
            set -- $(adaptive_pid_cycle "$temp_milli" "$setpoint" "$base_kp" "$base_ki" "$base_kd" "$last_error" "$integral_sum" "$prev_temp" "$ADAPT_SAVE")
            local pwm_raw=$1
            local tuned_kp=$2
            local tuned_ki=$3
            local tuned_kd=$4
            local new_integral=$5
            local new_error=$6
            local new_prev_temp=$7

            # Fallback to base params + standard PID if combined call failed
            if ! is_uint "$pwm_raw"; then
                set -- $(pid_pwm_raw "$temp_milli" "$setpoint" "$base_kp" "$base_ki" "$base_kd" "$last_error" "$integral_sum" "$prev_temp")
                pwm_raw=$1
                new_integral=$2
                new_error=$3
                new_prev_temp=$4
            fi

            # Apply PWM
            set_pwm_raw "$pwm_raw"

            # Check for fan stall (RPM sensor reports 0 while PWM is active)
            if [ "$pwm_raw" -gt 0 ]; then
                check_fan_stall
            fi

            # Save PID state for next iteration
            save_pid_state "$new_error" "$new_integral" "$new_prev_temp"
            return 0
        fi
        return 1
    fi

    # When switching away from PID mode, clean up adapt state
    rm -f "$ADAPT_SAVE"

    resolve_smart_window_milli

    if resolve_pwm_hwmon_cached; then
        case "$mode" in
            turbo)
                set_pwm_raw 255
                return 0
                ;;
            manual)
                raw=$(percent_to_raw "$manual_pwm")
                set_pwm_raw "$raw"
                return 0
                ;;
            *)
                set -- $(get_temp 2>/dev/null)
                temp_milli=$1

                [ -n "$temp_milli" ] || return 1

                raw=$(smart_pwm_raw "$temp_milli" "$SMART_WINDOW_OFF_MILLI" "$SMART_WINDOW_ON_MILLI")
                set_pwm_raw "$raw"
                return 0
                ;;
        esac
    fi

    case "$mode" in
        smart)
            set_fan_tp "$SMART_WINDOW_ON_MILLI" "$SMART_WINDOW_OFF_MILLI"
            ;;
        *)
            return 1
            ;;
    esac
}

print_smart_map() {
    local temp_milli=$1
    local min_milli=${2:-$FAN_LIB_SMART_MIN_MILLI}
    local max_milli=${3:-$FAN_LIB_SMART_MAX_MILLI}
    local max_rpm=$4

    if ! is_uint "$max_rpm"; then
        resolve_max_rpm
        max_rpm=$EFFECTIVE_MAX_RPM
    else
        max_rpm=$(clamp_uint "$max_rpm" "$FAN_LIB_SMART_MAX_RPM_MIN" "$FAN_LIB_SMART_MAX_RPM_MAX")
    fi

    raw=$(smart_pwm_raw "$temp_milli" "$min_milli" "$max_milli") || return 1
    rpm=$(estimate_rpm_from_raw "$raw" "$max_rpm") || return 1
    printf '%s %s\n' "$raw" "$rpm"
}

daemon_loop() {
    local interval=5
    local last_cache_refresh=0
    local now=0

    trap 'exit 0' TERM INT

    while :; do
        apply_current_config

        # Time-based cache refresh: every ~10 minutes
        now=$(date +%s 2>/dev/null) || now=0
        if [ "$now" -gt 0 ] && [ $(( now - last_cache_refresh )) -ge 600 ]; then
            last_cache_refresh=$now
            rm -f "$SAVE" "$PWM_SAVE"
            init_fan_tp
            resolve_pwm_hwmon_cached >/dev/null 2>&1 || true
        fi

        interval=$(read_uci_uint poll_interval 2>/dev/null) || interval=5
        interval=$(clamp_uint "$interval" 1 30)

        # Use background sleep + wait pattern so SIGTERM is handled promptly
        sleep "$interval" &
        wait $! 2>/dev/null
    done
}

usage() {
    echo "usage: $0 sub-command"
    echo 'where sub-command is one of:'
    echo '      get                     Get thermal trip setting'
    echo '      set ON_TEMP [OFF_TEMP]  Set thermal trip setting'
    echo '      temp                    Get current thermal temp and fan start temp'
    echo '      pwm-status              Get detected PWM runtime info'
    echo '      pwm-set RAW             Set PWM duty cycle (0-255)'
    echo '      smart-map TEMP [MIN [MAX [RPM]]]  Print raw PWM and estimated RPM for a temperature in milli-Celsius'
    echo '      apply                   Apply the current UCI profile once'
    echo '      disable                 Stop PWM output if supported'
    echo '      daemon                  Run the smart/manual/turbo control loop'
    echo '      init                    Init caches, internal used'
}

# Clean up cache files on disable
cleanup_cache() {
    rm -f "$SAVE" "$PWM_SAVE" "$PID_SAVE" "$ADAPT_SAVE"
}

case "$ACTION" in
    get)
        get_fan_tp_user
    ;;
    set)
        set_fan_tp "$@"
    ;;
    temp)
        get_temp
    ;;
    pwm-status)
        get_pwm_status
    ;;
    pwm-set)
        set_pwm_raw "$1"
    ;;
    smart-map)
        print_smart_map "$1" "$2" "$3" "$4"
    ;;
    apply)
        apply_current_config
    ;;
    disable)
        disable_pwm
        cleanup_cache
    ;;
    daemon)
        daemon_loop
    ;;
    init)
        rm -f "$SAVE" "$PWM_SAVE"
        init_fan_tp
        resolve_pwm_hwmon_cached >/dev/null 2>&1 || true
    ;;
    *)
        usage
        exit 1
    ;;
esac
